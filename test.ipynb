    "import torch\n",
    "import MyRCNN\n",
    "model = MyRCNN.Model()\n",
    "model.eval()\n",
    "for tensor, label in model.loader:\n",
    "    onnx_prog = torch.onnx.export(model.model, tensor, opset_version=18)\n",
    "    onnx_prog.save(\"model.onnx\")\n",
    "    break\n",
    "# onnx_prog.save(destination=\"myrcnn.onnx\")"
